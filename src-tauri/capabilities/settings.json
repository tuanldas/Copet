{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "settings",
  "description": "Capability for the Settings window (autostart, shortcut, pet-select, hook-install commands)",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:event:default",
    "store:default",
    "autostart:default",
    "global-shortcut:default",
    "positioner:default"
  ]
}

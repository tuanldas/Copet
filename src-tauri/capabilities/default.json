{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core capability for the pet overlay window (owner role: emits tama:state, listens tama:mutate)",
  "windows": ["pet"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:event:default",
    "opener:default",
    "store:default",
    "positioner:default",
    "window-state:default",
    "global-shortcut:default",
    "autostart:default",
    "notification:default"
  ]
}
